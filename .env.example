# =============================================
# Latta Backend — Environment Variables
# =============================================
# Copie este arquivo para .env e preencha os valores

# ---------- Required ----------

# PostgreSQL (Supabase pooler)
DATABASE_URL=postgresql://user:pass@host:6543/postgres

# Supabase (REST + Edge Functions — usado por dashboard.service)
SUPABASE_URL=https://kusqorpjtadcuooprpqb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
PASSWORD_RESET_SECRET=your_password_reset_secret_here

# CORS
ACCESS_LIST=http://localhost:5173,https://latta.app.br
FRONTEND_URL=http://localhost:5173,https://latta.app.br

# ---------- Firebase ----------
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"

# ---------- AWS S3 ----------
AWS_BUCKET_ACCESS_KEY_ID=your_access_key
AWS_BUCKET_SECRET_ACCESS_KEY=your_secret_key

# ---------- WhatsApp ----------
WHATSAPP_ACCESS_TOKEN=your_meta_token
WHATSAPP_PRIVATE_KEY="your_rsa_private_key"

# ---------- AI (optional) ----------
OPENAI_API_KEY=your_key
ANTHROPIC_API_KEY=your_key
GOOGLE_GENERATIVE_AI_API_KEY=your_key

# ---------- Integrations (optional) ----------
VAREJO_API_TOKEN=your_token
BROWSERBASE_API_KEY=your_key
BROWSERBASE_PROJECT_ID=your_project_id
USE_BROWSERBASE=false
CAPSOLVER_API_KEY=your_key
WEBHOOK_URL=https://your-n8n/webhook/stagehand
